# =============================================================================
#  Ara Workbench — Backend Environment
#  Copy to `.env` and fill in. Every variable here is validated at boot by
#  src/config/env.js — the process REFUSES TO START on an invalid config rather
#  than failing three hours later inside a request handler.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_NAME="Ara Workbench"

# The SPA's public URL. Used for CORS and for links inside emails.
CLIENT_URL=http://localhost:5173
# Extra allowed origins, comma-separated. CLIENT_URL is always included.
CORS_ORIGINS=

# Number of proxies in front of this app. 1 for Azure App Service / nginx.
# Get this wrong and every audit row records the load balancer's IP, and every
# IP-based rate limit becomes a single shared bucket for the whole internet.
TRUST_PROXY=1

# --- Database ----------------------------------------------------------------
# MySQL 8. Host port is 3307 (docker-compose remaps it) to avoid clashing with a
# MySQL you may already have on 3306. Note connection_limit: an Azure App Service
# B-tier instance has a low max_connections, and a pool per instance adds up fast.
DATABASE_URL="mysql://root:root@localhost:3307/ara_workbench?connection_limit=10&pool_timeout=20"
# Production Azure MySQL example. Use the restricted app user from db-setup.sql.
# DATABASE_URL="mysql://ara_workbench_app:<url-encoded-password>@<server>.mysql.database.azure.com:3306/ara_workbench?sslaccept=strict&connection_limit=10&pool_timeout=20"

# --- Authentication ----------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# These MUST be different from each other and MUST be rotated per environment.
JWT_ACCESS_SECRET=change-me-to-a-random-48-byte-base64-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-DIFFERENT-random-48-byte-base64-string

# Short by design. The httpOnly refresh cookie does the heavy lifting; a leaked
# access token is worth 15 minutes and cannot be renewed.
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# 12 is the current sensible floor. Raise it as hardware improves; never lower it.
BCRYPT_SALT_ROUNDS=12

# Minimum password length.
# WARNING: 6 is short. Against a leaked bcrypt hash it is recoverable offline, and
# NIST SP 800-63B recommends 8 as a floor. The composition rules in auth.dto.js are
# what stop "123456" at this length — do not remove them as well. Raise this when you can.
PASSWORD_MIN_LENGTH=6

REFRESH_COOKIE_NAME=aw_rt
# Leave blank for localhost. Set to the apex domain in production.
COOKIE_DOMAIN=
# MUST be true in production — the app refuses to boot otherwise.
COOKIE_SECURE=false

# --- Brute-force protection ---------------------------------------------------
MAX_FAILED_LOGINS=5
ACCOUNT_LOCK_MINUTES=15

# --- Password reset OTP -------------------------------------------------------
OTP_LENGTH=6
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
# Window between "OTP verified" and "new password submitted".
OTP_RESET_TOKEN_TTL_MINUTES=10

# --- Rate limiting ------------------------------------------------------------
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# --- Email --------------------------------------------------------------------
# false = emails are LOGGED, not sent. Correct for CI. In dev, prefer MailHog (below)
# so you can actually read the password-reset OTP.
MAIL_ENABLED=true

# ── LOCAL DEV (default): MailHog catches every outbound email ──────────────────
#   docker compose up -d mailhog     → read them at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_USER=
SMTP_PASSWORD=

# ── GMAIL ─────────────────────────────────────────────────────────────────────
# Gmail REJECTS your normal account password. You must create an App Password:
#   Google Account → Security → 2-Step Verification (must be ON) → App passwords
# Then paste the 16-character code below (spaces are fine).
#
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false          ← MUST be false on 587. See the note below.
#   SMTP_REQUIRE_TLS=true
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=abcd efgh ijkl mnop
#   MAIL_FROM_ADDRESS=you@gmail.com     ← Gmail rewrites this to your account anyway
#
# ── OFFICE 365 ────────────────────────────────────────────────────────────────
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_REQUIRE_TLS=true
#
# ── SENDGRID / MAILGUN / SES (recommended for production) ─────────────────────
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASSWORD=<your API key>
#
# ⚠ THE #1 SMTP MISTAKE, spelled out:
#   SMTP_SECURE means "open the connection with TLS immediately" (implicit TLS).
#   It does NOT mean "use encryption".
#       port 465  → SMTP_SECURE=true
#       port 587  → SMTP_SECURE=FALSE  + SMTP_REQUIRE_TLS=true   (STARTTLS upgrade)
#       port 25   → SMTP_SECURE=false
#   Setting it true on 587 makes the client wait forever for a handshake the server
#   will never start. It looks exactly like a firewall problem. It is not.

# Only for an internal relay with a self-signed certificate. NEVER for Gmail/SendGrid.
SMTP_ALLOW_SELF_SIGNED=false
# Logs the entire SMTP conversation. Turn on when mail fails and you cannot see why.
SMTP_DEBUG=false

MAIL_FROM_NAME="Ara Workbench"
MAIL_FROM_ADDRESS=no-reply@ara-workbench.local

# Verify it works WITHOUT resetting anyone's password:
#   Settings → Mail → "Send test email", or POST /api/v1/system/mail/test

# --- Uploads ------------------------------------------------------------------
UPLOAD_DIR=storage/uploads
MAX_AVATAR_SIZE_MB=2

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=info
LOG_DIR=storage/logs
LOG_RETENTION_DAYS=30

# --- Scheduled jobs -----------------------------------------------------------
# Set false on any instance that must never run cron.
# NOTE: leaving this true on multiple instances is SAFE — every job takes a
# database-backed distributed lock first (see src/jobs/lock.js).
SCHEDULER_ENABLED=true

# The 180-day rule from the brief. It is configurable because "180" is a business
# policy, and business policies must not require a redeploy to change.
TASK_RETENTION_DAYS=180
RETENTION_BATCH_SIZE=1000

# All cron expressions are evaluated in this timezone — NOT the server's, which
# on Azure is UTC and would roll the working day over at 05:30 IST.
CRON_TIMEZONE=Asia/Kolkata

CRON_RETENTION_CLEANUP=5 0 * * *      # 00:05 daily — the 180-day purge
CRON_ROLLUP=20 0 * * *                # 00:20 daily — materialise analytics
CRON_HOURLY_REMINDER=50 * * * *       # :50 each hour — nudge missing updates
CRON_LEAD_DIGEST=30 13,18 * * 1-5     # 13:30 & 18:30 weekdays — Tech Lead digest
CRON_MANAGEMENT_SUMMARY=0 19 * * 1-5  # 19:00 weekdays — Management summary
CRON_AUTO_APPROVE=40 * * * *          # :40 each hour — auto-approve sheets unreviewed past the window

# --- Seed ---------------------------------------------------------------------
# The first Management account, created on first startup.
# The app REFUSES TO BOOT in production if the default password below is unchanged.
SEED_ADMIN_EMAIL=admin@ara-workbench.local
SEED_ADMIN_PASSWORD=ChangeMe@Admin123
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Administrator

# true = also seed 5 teams, 10 users and 5 projects across the four departments.
# Every demo user's password is Password@2026!
SEED_DEMO_DATA=true

# --- Docs ---------------------------------------------------------------------
# Turn OFF in production unless the API is behind the corporate network — a public
# map of every endpoint and parameter is free reconnaissance for an attacker.
SWAGGER_ENABLED=true
