# Root convenience example.
# The backend reads environment from backend/.env in local development.
# In Azure App Service these values are configured as app settings instead.

DATABASE_URL="mysql://ara_workbench_app:<url-encoded-password>@<server>.mysql.database.azure.com:3306/ara_workbench?sslaccept=strict&connection_limit=10&pool_timeout=20"
JWT_ACCESS_SECRET="<fresh-random-48-byte-secret>"
JWT_REFRESH_SECRET="<different-fresh-random-48-byte-secret>"
SEED_ADMIN_PASSWORD="<strong-temporary-admin-password>"
COOKIE_SECURE=true
